#include <stdio.h>

int main() {
    float temp[7][3];
    int i, j;
    float max, sum;

    for(i = 0; i < 7; i++) {
        for(j = 0; j < 3; j++) {
            scanf("%f", &temp[i][j]);
        }
    }

    max = temp[0][0];

    for(i = 0; i < 7; i++) {
        for(j = 0; j < 3; j++) {
            if(temp[i][j] > max)
                max = temp[i][j];
        }
    }

    printf("Highest Temperature = %.2f\n", max);

    for(i = 0; i < 7; i++) {
        sum = 0;
        for(j = 0; j < 3; j++) {
            sum += temp[i][j];
        }
        printf("Day %d Average = %.2f\n", i+1, sum/3);
    }

    return 0;
}
