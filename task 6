#include <stdio.h>

int main() {
    int a[2][2] = {
        {1, 2},
        {3, 4}
    };

    int b[2][2] = {
        {5, 6},
        {7, 8}
    };

    int r[2][2];
    int i, j, k;

    printf("Matrix A:\n");
    for(i=0;i<2;i++){
        for(j=0;j<2;j++){
            printf("%d ", a[i][j]);
        }
        printf("\n");
    }

    printf("\nMatrix B:\n");
    for(i=0;i<2;i++){
        for(j=0;j<2;j++){
            printf("%d ", b[i][j]);
        }
        printf("\n");
    }

    for(i=0;i<2;i++){
        for(j=0;j<2;j++){
            r[i][j]=0;
            for(k=0;k<2;k++){
                r[i][j]+=a[i][k]*b[k][j];
            }
        }
    }

    printf("\nResult Matrix:\n");
    for(i=0;i<2;i++){
        for(j=0;j<2;j++){
            printf("%d ", r[i][j]);
        }
        printf("\n");
    }

    return 0;
}
